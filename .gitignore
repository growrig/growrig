# Embedded web build — populated by `make build`, only the placeholder is tracked
/growcore/internal/webui/dist/*
!/growcore/internal/webui/dist/.gitkeep

# Node / SvelteKit
node_modules/
/web/.svelte-kit/
/web/build/

# Environment files (secrets); keep the example
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.claude
